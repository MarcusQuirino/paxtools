# Convex deployment config
# Run `bunx convex dev --once` to generate your .env.local automatically
CONVEX_DEPLOYMENT=dev:your-project-name
VITE_CONVEX_URL=https://your-project-name.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project-name.convex.site

# E2E test auth (local dev only — NEVER set in production)
# When set to "1", enables the test-only credentials provider in convex/auth.ts
# and a hidden test sign-in form in /signin. See docs/qa/infra-plan.md.
TEST_AUTH=
VITE_TEST_AUTH=
TEST_AUTH_PASSWORD=
