{
  "name": "paxtools",
  "version": "1.3.0",
  "description": "Rastreador de Progressao Pessoal para escoteiros brasileiros do Ramo Escoteiro",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarcusQuirino/paxtools.git"
  },
  "scripts": {
    "dev": "bunx concurrently --names convex,vite -c cyan,magenta \"bunx convex dev\" \"vite dev\"",
    "dev:frontend": "vite dev",
    "dev:backend": "bunx convex dev",
    "build": "vite build",
    "test": "bun test src convex",
    "test:e2e": "TEST_AUTH=1 playwright test",
    "test:e2e:ui": "TEST_AUTH=1 playwright test --ui",
    "test:e2e:seed": "TEST_AUTH=1 bunx convex run testing:seedTestUsers",
    "test:e2e:wipe": "TEST_AUTH=1 bunx convex run testing:wipeTestData",
    "test:e2e:reset": "bun run test:e2e:wipe && bun run test:e2e:seed",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/react-query": "^0.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-router": "^1.168.1",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.2",
    "ai": "^6.0.209",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "lucide-react": "^0.545.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.53",
    "nitro": "^3.0.260311-beta",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.1",
    "xlsx": "^0.18.5"
  }
}